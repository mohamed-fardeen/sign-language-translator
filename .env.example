# --- Environment ---
APP_ENV=local
LOG_LEVEL=INFO

# --- MLflow (local) ---
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT=signlang-baselines

# --- DVC (local default; remote is opt-in) ---
DVC_REMOTE=

# --- Auth (JWT HS256) ---
# In prod, set this in the Render service env, NOT in the repo.
JWT_SECRET=change-me-in-prod
JWT_ALGORITHM=HS256
JWT_TTL_SECONDS=900
RATE_LIMIT_PER_MIN=60

# --- Serving ---
SERVE_HOST=0.0.0.0
SERVE_PORT=8000
MODEL_VERSION=latest
BATCH_WINDOW_MS=30
MAX_BATCH_SIZE=32
BEAM_SIZE=8

# --- Model (v1) ---
VOCAB_SIZE=500
CLIP_FRAMES=64

# --- Paths ---
DATA_DIR=./data
ARTIFACTS_DIR=./artifacts
CONFIGS_DIR=./configs